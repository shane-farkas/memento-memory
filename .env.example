# Memento Configuration
# Copy to .env: cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────────
# Provider: anthropic, openai, gemini, ollama (auto-detected from API key if not set)
# MEMENTO_LLM_PROVIDER=anthropic

# API key for your chosen provider (or use provider-specific env vars below)
# MEMENTO_LLM_API_KEY=

# Provider-specific keys (alternative to MEMENTO_LLM_API_KEY):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# For Ollama or other OpenAI-compatible endpoints:
# MEMENTO_LLM_PROVIDER=ollama
# MEMENTO_LLM_BASE_URL=http://localhost:11434/v1

# Model overrides (optional — sensible defaults per provider):
# MEMENTO_EXTRACTION_MODEL=
# MEMENTO_CHAT_MODEL=

# ── Embeddings ───────────────────────────────────────────────────
# Provider: sentence-transformers (local, default) or openai
# MEMENTO_EMBEDDING_PROVIDER=sentence-transformers

# ── Storage ──────────────────────────────────────────────────────
# MEMENTO_DB_PATH=~/.memento/memento.db
